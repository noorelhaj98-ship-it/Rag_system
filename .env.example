# ─── Embedding Service ────────────────────────────────────────────────
EMBEDDING_SERVICE_TYPE=aragemma
EMBEDDING_API_URL=http://your-embedding-server:6001/embed
EMBED_TIMEOUT=120

# ─── Qdrant Vector Store ─────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                        # leave blank for local
QDRANT_COLLECTION=my_collection_hybrid

# ─── LLM (DeepSeek) ──────────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ─── Retrieval ────────────────────────────────────────────────────────
TOP_K=6
TOP_K_DENSE=100
TOP_K_KEYWORD=100
TOP_K_FINAL=6
FUSION_TYPE=RRF
RRF_K=60

# ─── Reranker ─────────────────────────────────────────────────────────
RERANKER_ENABLED=true
RERANKER_TOP_K=30
RERANKER_MODEL=cross-encoder

# ─── Rate Limiting ────────────────────────────────────────────────────
RATE_LIMIT=10/minute

# ─── Observability (optional) ─────────────────────────────────────────
LOGFIRE_TOKEN=

# ─── Conversation ─────────────────────────────────────────────────────
MAX_HISTORY=10
